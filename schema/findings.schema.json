{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/trifecta-lens/schema/findings.schema.json",
  "title": "trifecta-lens findings NDJSON line (v1)",
  "description": "One finding per NDJSON line (keys sorted, sort_keys=True). A public, frozen contract (SPEC.md §7.1). Discriminated by `tier`: a realized line carries trace evidence; a capability line (posture/reachable) carries inventory capability and structurally cannot carry realized's evidence keys. Consumers MUST ignore unknown fields; a new optional field is a minor version bump, a removal/rename/retype is a major bump.",
  "type": "object",
  "required": ["schema_version", "tier"],
  "properties": {
    "schema_version": { "const": "1.0" }
  },
  "oneOf": [
    { "$ref": "#/$defs/realized" },
    { "$ref": "#/$defs/capability" }
  ],
  "$defs": {
    "realized": {
      "title": "realized finding",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version", "tier", "family", "summary", "note", "scope",
        "sink", "path", "path_edges", "path_basis", "legs",
        "legs_observed", "legs_not_observed", "masked_values", "detected_under"
      ],
      "properties": {
        "schema_version": { "const": "1.0" },
        "tier": { "const": "realized" },
        "family": { "type": "string" },
        "summary": { "type": "string" },
        "note": { "type": "string" },
        "scope": { "type": "string" },
        "sink": {
          "type": "object",
          "additionalProperties": false,
          "required": ["event", "tool"],
          "properties": {
            "event": { "type": "string" },
            "tool": { "type": ["string", "null"] }
          }
        },
        "path": { "type": "array", "items": { "type": "string" } },
        "path_edges": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["from", "to", "basis"],
            "properties": {
              "from": { "type": "string" },
              "to": { "type": "string" },
              "basis": { "enum": ["causal", "temporal", "mixed"] }
            }
          }
        },
        "path_basis": { "enum": ["causal", "temporal", "mixed"] },
        "legs": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["role", "event", "tool", "note", "catalog_entry"],
            "properties": {
              "role": { "type": "string" },
              "event": { "type": "string" },
              "tool": { "type": ["string", "null"] },
              "note": { "type": "string" },
              "catalog_entry": { "type": "string" }
            }
          }
        },
        "legs_observed": { "type": "array", "items": { "type": "string" } },
        "legs_not_observed": { "type": "array", "items": { "type": "string" } },
        "masked_values": { "type": "array", "items": { "type": "string" } },
        "detected_under": {
          "type": "object",
          "additionalProperties": false,
          "required": ["match", "min_value_chars", "normalization"],
          "properties": {
            "match": { "type": "string" },
            "min_value_chars": { "type": "integer" },
            "normalization": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    },
    "capability": {
      "title": "capability finding (posture / reachable)",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version", "tier", "family", "summary", "note", "scope",
        "sink", "context", "legs", "legs_present", "legs_absent", "disclosure"
      ],
      "properties": {
        "schema_version": { "const": "1.0" },
        "tier": { "enum": ["posture", "reachable"] },
        "family": { "type": "string" },
        "summary": { "type": "string" },
        "note": { "type": "string" },
        "scope": { "type": "string" },
        "sink": {
          "type": "object",
          "additionalProperties": false,
          "required": ["tool"],
          "properties": {
            "tool": { "type": "string" }
          }
        },
        "context": {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "provenance"],
          "properties": {
            "id": { "type": "string" },
            "provenance": { "type": "string" }
          }
        },
        "legs": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["role", "tools"],
            "properties": {
              "role": { "type": "string" },
              "tools": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["tool", "note", "catalog_entry"],
                  "properties": {
                    "tool": { "type": "string" },
                    "note": { "type": "string" },
                    "catalog_entry": { "type": "string" }
                  }
                }
              }
            }
          }
        },
        "legs_present": { "type": "array", "items": { "type": "string" } },
        "legs_absent": { "type": "array", "items": { "type": "string" } },
        "disclosure": { "type": "string" }
      }
    }
  }
}
